# ----------------------------------------------------------------------------
# Site configuration
# ----------------------------------------------------------------------------
# The canonical, public URL of your deployed site (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://example.com

# ----------------------------------------------------------------------------
# Admin dashboard (development only — never used in production)
# ----------------------------------------------------------------------------
# Password required to access the local /admin dashboard.
ADMIN_PASSWORD=change-me-in-dev

# ----------------------------------------------------------------------------
# Analytics (optional — leave blank to disable)
# ----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token (the content of the meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ----------------------------------------------------------------------------
# Monetization (optional — ads are disabled by default)
# ----------------------------------------------------------------------------
# Master switch for ad slots. Set to "true" to enable rendering of ad units.
NEXT_PUBLIC_ADS_ENABLED=false

# Google AdSense publisher ID, e.g. ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
